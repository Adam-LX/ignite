{
	"name": "ignite",
	"private": true,
	"version": "0.3.26",
	"description": "Ignite — car soccer arcade game",
	"author": "FlyBall",
	"homepage": "https://codeberg.org/Adam-LX/ignite",
	"repository": {
		"type": "git",
		"url": "https://codeberg.org/Adam-LX/ignite.git"
	},
	"type": "module",
	"scripts": {
		"predev": "bash scripts/bake-donation.sh && bash scripts/ensure-mp-relay.sh",
		"dev": "vite",
		"dev:desktop": "bash scripts/dev-desktop.sh",
		"start": "bash scripts/run-desktop.sh",
		"dev:force": "vite --force",
		"build": "tsc && vite build && npm run diagnostic",
		"diagnostic": "npm run audit:physics && npx vite-node scripts/runDiagnosticAutopilot.ts && npx vite-node scripts/runKickoffDriveTest.ts",
		"probe:matches": "vite-node scripts/runMatchProbe.ts",
		"probe:matches:smoke": "vite-node scripts/runMatchProbe.ts -- --matches 1 --seconds 15",
		"audit:chase": "node scripts/audit-chase-camera.mjs",
		"audit:chase:menu": "node scripts/audit-chase-camera.mjs --path=menu",
		"audit:chase:survey": "node scripts/audit-chase-camera.mjs --path=autostart --survey",
		"audit:chase:loop": "bash scripts/chase-camera-fix-loop.sh --path menu",
		"audit:replay": "node scripts/audit-replay.mjs",
		"audit:wall-ceiling": "vite-node scripts/runWallCeilingAudit.ts",
		"audit:goal-drive": "vite-node scripts/runGoalDriveAudit.ts",
		"audit:grip": "vite-node scripts/runGripPowerslideAudit.ts",
		"audit:ball": "vite-node scripts/runBallPhysicsAudit.ts",
		"audit:menu-orbit": "node scripts/audit-menu-orbit.mjs",
		"audit:physics": "vitest run tests/physics",
		"audit:dodge": "vite-node scripts/runForwardDodgeAudit.ts",
		"audit:second-jump": "vite-node scripts/runSecondJumpAudit.ts",
		"test:kickoff": "vite-node scripts/runKickoffDriveTest.ts",
		"fetch:audio": "bash scripts/fetch_audio_assets.sh",
		"music:setup": "bash scripts/music/flyball-music setup",
		"music:generate": "bash scripts/music/flyball-music generate --style racer_like --duration 90 --seed 42 --out public/assets/audio/music/match_loop.mp3",
		"music:stable-audio:up": "bash scripts/music/flyball-music stable-audio up",
		"music:stable-audio:health": "bash scripts/music/flyball-music stable-audio health",
		"music:synth": "bash scripts/music/flyball-music synth --bpm 124 --out public/assets/audio/music/match_moroder_synth.mp3",
		"music:ace-step:up": "bash scripts/music/flyball-music ace-step up",
		"music:ace-step:health": "bash scripts/music/flyball-music ace-step health",
		"music:vocal": "bash scripts/music/flyball-music vocal --style prodigy_vocal_pl --duration 90 --seed 42 --out public/assets/audio/music/match_vocal_prodigy_pl.mp3",
		"music:vocal:en": "bash scripts/music/flyball-music vocal --style prodigy_vocal --duration 90 --seed 42 --out public/assets/audio/music/match_msx.mp3",
		"music:ignite:infinite": "bash scripts/music/flyball-music vocal --style ignite_infinite_grid --duration 90 --seed 101 --out public/assets/audio/music/match_ignite_infinite.mp3",
		"music:ignite:chrome": "bash scripts/music/flyball-music vocal --style ignite_chrome_overdrive --duration 90 --seed 202 --out public/assets/audio/music/match_ignite_chrome.mp3",
		"music:ignite:apex": "bash scripts/music/flyball-music vocal --style ignite_apex_rush --duration 90 --seed 303 --out public/assets/audio/music/match_ignite_apex.mp3",
		"music:ignite:hiphop": "bash scripts/music/flyball-music vocal --style ignite_hip_hop_slipstream --duration 90 --seed 404 --out public/assets/audio/music/match_ignite_hiphop.mp3",
		"music:ignite:more-than": "bash scripts/music/flyball-music vocal --style ignite_more_than_fire --duration 90 --seed 505 --out public/assets/audio/music/match_ignite_more_than.mp3",
		"music:ignite:grime": "bash scripts/music/flyball-music vocal --style ignite_grime_pitlane --duration 90 --seed 601 --out public/assets/audio/music/match_ignite_grime.mp3",
		"music:ignite:boom-bap": "bash scripts/music/flyball-music vocal --style ignite_boom_bap_boost --duration 90 --seed 602 --out public/assets/audio/music/match_ignite_boom_bap.mp3",
		"music:ignite:dnb-rap": "bash scripts/music/flyball-music vocal --style ignite_dnb_doubletime --duration 90 --seed 603 --out public/assets/audio/music/match_ignite_dnb_rap.mp3",
		"music:ignite:electro-rap": "bash scripts/music/flyball-music vocal --style ignite_electro_clash_rap --duration 90 --seed 604 --out public/assets/audio/music/match_ignite_electro_rap.mp3",
		"music:ignite:rap-pack": "npm run music:ignite:grime && npm run music:ignite:boom-bap && npm run music:ignite:dnb-rap && npm run music:ignite:electro-rap",
		"music:ignite:all": "npm run music:ignite:infinite && npm run music:ignite:chrome && npm run music:ignite:apex && npm run music:ignite:hiphop && npm run music:ignite:more-than && npm run music:ignite:rap-pack",
		"assets:car": "FLYBALL_ROOT=$PWD bash -c 'BLENDER=$(ls -d /nix/store/*-blender-*/bin/blender 2>/dev/null | tail -1); \"$BLENDER\" --background --python scripts/blender_export_car.py'",
		"assets:car-body": "FLYBALL_ROOT=$PWD bash -c 'BLENDER=$(ls -d /nix/store/*-blender-*/bin/blender 2>/dev/null | tail -1); \"$BLENDER\" --background --python generate_car.py'",
		"assets:car-texture": "python3 scripts/generate_car_comfyui.py",
		"assets:pitch-logo": "/nix/store/0k05rim4nalb3sshxdrbkqski6w9l907-python3-3.13.13-env/bin/python3 scripts/generate_ignite_pitch_logo_comfyui.py",
		"assets:meshy-car": "bash scripts/meshy_prep_car.sh",
		"meshy:build-car": "vite-node scripts/meshy/pipelineCar.ts",
		"meshy:retexture-car": "vite-node scripts/meshy/pipelineCar.ts --retexture",
		"meshy:optimize-car": "vite-node scripts/meshyOptimizeCar.ts",
		"meshy:build-arena": "vite-node scripts/meshy/pipelineArena.ts",
		"meshy:build-arena:textures": "vite-node scripts/meshy/pipelineArena.ts -- --textures-only",
		"meshy:build-grass": "vite-node scripts/meshy/pipelineArena.ts -- --grass-only",
		"meshy:build-ceiling": "vite-node scripts/meshy/pipelineArena.ts -- --ceiling-only",
		"meshy:build-sky": "vite-node scripts/meshy/pipelineArena.ts -- --sky-only",
		"meshy:sync-manifest": "vite-node scripts/meshy/syncManifest.ts",
		"meshy:build-ball": "vite-node scripts/meshy/pipelineBall.ts",
		"meshy:build-ball:texture": "vite-node scripts/meshy/pipelineBall.ts -- --texture-only",
		"meshy:prep-ball": "vite-node scripts/meshy/pipelineBall.ts -- --local-only",
		"meshy:build-powerups": "vite-node scripts/meshy/pipelinePowerUps.ts",
		"meshy:build-goal-complete": "vite-node scripts/meshy/pipelineGoalComplete.ts",
		"meshy:build-all": "vite-node scripts/meshy/pipelineAll.ts",
		"meshy:build-all:textures": "vite-node scripts/meshy/pipelineAll.ts -- --textures-only",
		"meshy:full-throttle": "vite-node scripts/meshy/pipelineAll.ts -- --force",
		"content:design": "bash scripts/content/gemini-design-pass.sh",
		"content:design:validate": "bash scripts/content/gemini-design-pass.sh --skip-api",
		"catalog:sync-design": "vite-node scripts/syncCatalogFromDesign.ts",
		"trellis:health": "vite-node scripts/trellis/health.ts",
		"trellis:restart": "sudo systemctl start podman-trellis3d.service && npm run trellis:health",
		"trellis:build-car": "vite-node scripts/trellis/pipelineCar.ts",
		"trellis:build-arena-props": "vite-node scripts/trellis/pipelineArenaProp.ts",
		"trellis:build-item": "vite-node scripts/trellis/pipelineItem.ts",
		"content:sync-items": "bash scripts/content/sync-item-catalog.sh",
		"gemini:garage-ghost": "bash scripts/content/gemini-garage-ghost-audit.sh",
		"gemini:wheel-system": "bash scripts/content/gemini-wheel-system-audit.sh",
		"gemini:cars-audit": "bash scripts/content/gemini-cars-audit-loop.sh",
		"cars:audit": "node scripts/garage-cars-gemini-audit.mjs",
		"cars:prep-all": "bash scripts/content/batch-prep-trellis-cars.sh",
		"cars:restore-raw": "bash scripts/content/restore-trellis-from-raw.sh",
		"cars:prep-pruned": "bash scripts/content/prep-trellis-cars-pruned.sh",
		"cars:validate": "node scripts/validateGlb.mjs --catalog",
		"cars:check": "bash scripts/content/cars-check.sh",
		"cars:simulate-mount": "bash scripts/content/cars-check.sh",
		"cars:audit:visual": "bash scripts/content/gemini-cars-audit-loop.sh",
		"trellis:batch-items": "vite-node scripts/trellis/batchItemsFromDesign.ts",
		"trellis:batch": "vite-node scripts/trellis/batchFromDesign.ts --missing-only",
		"trellis:batch:all": "vite-node scripts/trellis/batchFromDesign.ts",
		"trellis:regen-cars": "mkdir -p public/assets/cars/.work && vite-node scripts/trellis/batchFromDesign.ts --regen-all 2>&1 | tee public/assets/cars/.work/trellis-regen.log",
		"trellis:batch-status": "vite-node scripts/trellis/batchStatus.ts",
		"trellis:batch-watch": "vite-node scripts/trellis/batchStatus.ts -- --watch",
		"trellis:prep-car": "vite-node scripts/trellis/pipelineCar.ts --prep-only",
		"diagnose:car-upright": "vite-node scripts/diagnose-car-upright.ts",
		"audit:car-orient": "vite-node scripts/render-orient-audit.mjs",
		"wheels:build": "bash scripts/build_procedural_wheels.sh",
		"wheels:extract": "bash scripts/content/batch-extract-car-wheels.sh",
		"trellis:sync-arena-manifests": "vite-node scripts/trellis/syncArenaManifest.ts",
		"icons:render": "node scripts/render-app-icon.mjs",
		"music:arrange": "bash scripts/music/flyball-music arrange",
		"music:arrange:quick": "bash scripts/music/flyball-music arrange --skip-ace",
		"music:studio": "bash scripts/music/flyball-music studio",
		"music:generate:commercial": "bash scripts/music/flyball-music generate --backend stable-audio --style racer_like --duration 90 --seed 42 --out public/assets/audio/music/match_loop.mp3",
		"preview": "vite preview",
		"lint": "biome check ./src",
		"lint:fix": "biome check --write ./src",
		"prepare": "husky",
		"build:web": "tsc && vite build",
		"build:web:desktop": "bash scripts/bake-donation.sh && bash scripts/bake-mp-endpoint.sh --release && tsc && ELECTRON_BUILD=1 vite build && npm run build:mp-server",
		"build:mp-server": "vite build --config vite.mp-server.config.ts && cp .build/mp-server.cjs electron/mp-server.cjs",
		"build:win": "npm run build:web:desktop && electron-builder --win zip --x64",
		"build:win:dir": "npm run build:web:desktop && electron-builder --win dir --x64",
		"build:deb": "npm run build:web:desktop && electron-builder --linux deb --x64",
		"publish:codeberg": "bash scripts/publish-codeberg.sh all",
		"publish:codeberg:win": "bash scripts/publish-codeberg.sh win",
		"publish:codeberg:linux": "bash scripts/publish-codeberg.sh linux",
		"publish:codeberg:source": "bash scripts/publish-codeberg.sh source",
		"publish:github": "bash scripts/publish-github-releases.sh --push-downloads",
		"publish:github:mirror": "bash scripts/publish-github-mirror.sh",
		"publish:bot-policy": "bash scripts/publish-bot-policy-github.sh",
		"test": "vitest run",
		"test:smoke": "npm test && npm run diagnostic && bash scripts/electron-kickoff-test.sh",
		"test:e2e": "bash scripts/run-e2e-match.sh",
		"test:e2e:online": "bash scripts/run-e2e-online.sh",
		"test:e2e:local-2v2": "node scripts/run-e2e-local-2v2.mjs",
		"test:e2e:public-relay": "bash scripts/run-e2e-public-relay.sh",
		"test:watch": "vitest",
		"train:bots": "vite-node --script scripts/trainBots.ts",
		"train:bots:smoke": "BOT_TRAIN_GENS=2 BOT_TRAIN_POP=4 BOT_TRAIN_SEC=6 vite-node --script scripts/trainBots.ts",
		"train:bots:cuda": "bash scripts/train-bots-cuda.sh",
		"train:bots:cuda:smoke": "CUDA_TRAIN_GENS=4 CUDA_TRAIN_POP=12 CUDA_TRAIN_EPISODES=8 bash scripts/train-bots-cuda.sh",
		"publish:trained-policy": "vite-node --script scripts/publishTrainedPolicy.ts",
		"coach:bots:ollama": "node scripts/ollamaBotCoach.mjs",
		"bot:progress": "vite-node scripts/botProgress.ts",
		"mp:server": "vite-node server/roomServer.ts",
		"audit:wall-feel": "vite-node scripts/probeWallRideFeel.ts",
		"audit:wall-detail": "vite-node scripts/auditWallDetail.ts"
	},
	"main": "electron/main.cjs",
	"lint-staged": {
		"*": "bash scripts/lint-staged-biome.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.2",
		"@types/ws": "^8.18.1",
		"electron": "^33.2.1",
		"electron-builder": "^25.1.8",
		"husky": "9.1.6",
		"lint-staged": "^15.2.10",
		"playwright": "^1.49.1",
		"typescript": "^5.5.3",
		"vite": "^5.4.1",
		"vite-node": "^3.2.4",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@dimforge/rapier3d-compat": "^0.14.0",
		"@types/three": "^0.168.0",
		"postprocessing": "^6.37.3",
		"three": "^0.168.0",
		"three.quarks": "^0.15.6",
		"ws": "^8.18.3"
	},
	"build": {
		"appId": "com.flyball.ignite",
		"productName": "Ignite",
		"copyright": "MIT",
		"publish": null,
		"asar": true,
		"asarUnpack": [
			"**/*.wasm",
			"**/*.glb",
			"**/*.mp3",
			"**/*.ogg",
			"**/*.wav"
		],
		"compression": "maximum",
		"directories": {
			"output": "release",
			"buildResources": "assets"
		},
		"files": [
			"dist/**/*",
			"!dist/**/*.provenance.json",
			"!dist/**/.work/**",
			"electron/**/*",
			"package.json"
		],
		"win": {
			"icon": "assets/icon.ico",
			"signAndEditExecutable": true,
			"requestedExecutionLevel": "asInvoker",
			"target": [
				{
					"target": "zip",
					"arch": [
						"x64"
					]
				}
			],
			"artifactName": "Ignite-${version}-win64.${ext}"
		},
		"linux": {
			"icon": "assets/icon.png",
			"target": [
				"deb"
			],
			"category": "Game",
			"maintainer": "Adam-LX <adam-lx@noreply.codeberg.org>",
			"synopsis": "Ignite — car soccer arcade game",
			"description": "Ignite is a car soccer arcade game. Fullscreen desktop build with offline assets.",
			"executableName": "ignite",
			"artifactName": "Ignite-${version}-linux-amd64.${ext}",
			"desktop": {
				"Name": "Ignite",
				"GenericName": "Car Soccer",
				"Comment": "Car soccer arcade game",
				"Categories": "Game;",
				"Keywords": "ignite;car;soccer;game;"
			}
		},
		"deb": {
			"packageName": "ignite",
			"priority": "optional",
			"depends": [
				"gconf2",
				"gconf-service",
				"libnotify4",
				"libappindicator1",
				"libxtst6",
				"libnss3"
			]
		}
	}
}
